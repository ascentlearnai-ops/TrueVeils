{
  "name": "truveil-recruiter",
  "version": "1.0.0",
  "description": "Truveil Recruiter App",
  "main": "main.js",
  "author": "Truveil Inc.",
  "scripts": {
    "test": "node --test test/*.test.js",
    "prestart": "node scripts/write-runtime-config.js",
    "start": "electron .",
    "dev": "electron . --dev",
    "prebuild:mac": "node scripts/write-runtime-config.js --production",
    "build:mac": "electron-builder --mac",
    "prebuild:win": "node scripts/write-runtime-config.js --production",
    "build:win": "electron-builder --win",
    "prebuild:all": "node scripts/write-runtime-config.js --production",
    "build:all": "electron-builder --mac --win"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.24.0",
    "@remotion/install-whisper-cpp": "^4.0.467",
    "@supabase/supabase-js": "^2.39.0",
