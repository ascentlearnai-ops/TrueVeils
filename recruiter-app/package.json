    "ffmpeg-static": "^5.2.0",
    "form-data": "^4.0.6",
    "node-fetch": "^3.3.2",
    "openai": "^4.28.0",
    "ws": "^8.21.0"
  },
  "devDependencies": {
    "electron": "^31.7.7",
    "electron-builder": "^24.9.1"
  }
}
